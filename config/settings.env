# ============================================================
#  new_env — configuration
#  USERNAME and project folder are prompted at runtime.
# ============================================================

# --- Modules (true / false) ---
NGINX_INSTALL=true
MYSQL_INSTALL=true
PHPMYADMIN_INSTALL=true
PHP_INSTALL=true

# --- PHP versions (space-separated) ---
PHP_VERSIONS="8.1 8.2 8.3"
